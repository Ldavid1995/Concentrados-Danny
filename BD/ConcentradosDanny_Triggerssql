---------------* Triggers *------------------

--1.TRG_ALERTA_STOCK

CREATE OR REPLACE TRIGGER trg_alerta_stock
AFTER UPDATE OF existencias ON producto
FOR EACH ROW
BEGIN
    IF :NEW.existencias <= :NEW.stock_minimo THEN
        INSERT INTO alerta_stock (id_producto, mensaje)
        VALUES (:NEW.id_producto, '¡ALERTA! El producto ' || :NEW.nombre || ' tiene un inventario bajo de: ' || :NEW.existencias || ' unidades.');
    END IF;
END;
/

--2.TRG_AUDIT_PRECIOS

CREATE OR REPLACE TRIGGER trg_audit_precios
BEFORE UPDATE OF precio ON producto
FOR EACH ROW
BEGIN
-- Si el precio varía más del 50%, se puede levantar una excepción o alertar
    IF :NEW.precio < (:OLD.precio * 0.5) THEN
        DBMS_OUTPUT.PUT_LINE('Advertencia: El precio bajó más de la mitad.');
    END IF;
END;
/

--3. TRG_ACTUALIZA_STOCK
-- Descuenta stock del producto al insertar un detalle de pedido
CREATE OR REPLACE TRIGGER trg_actualiza_stock
AFTER INSERT ON detalle_pedido
FOR EACH ROW
BEGIN
    UPDATE producto
    SET stock = stock - :NEW.cantidad
    WHERE id_producto = :NEW.id_producto;

    IF SQL%ROWCOUNT = 0 THEN
        RAISE_APPLICATION_ERROR(-20001, 'No se encontró el producto para actualizar el stock.');
    END IF;
END;
/

--4. TRG_CALCULA_TOTAL_PEDIDO
-- Recalcula automáticamente el total del pedido cada vez que se
-- inserta, actualiza o elimina un detalle asociado
CREATE OR REPLACE TRIGGER trg_calcula_total_pedido
AFTER INSERT OR UPDATE OR DELETE ON detalle_pedido
FOR EACH ROW
DECLARE
    v_id_pedido pedido.id_pedido%TYPE;
    v_total     NUMBER;
BEGIN
    v_id_pedido := NVL(:NEW.id_pedido, :OLD.id_pedido);

    SELECT NVL(SUM(subtotal), 0)
    INTO v_total
    FROM detalle_pedido
    WHERE id_pedido = v_id_pedido;

    UPDATE pedido
    SET total = v_total
    WHERE id_pedido = v_id_pedido;
END;
/

--5. TRG_ALERTA_VENCIMIENTO_LOTE
-- Genera una alerta si un lote se registra o actualiza con una
-- fecha de vencimiento próxima (30 días o menos)
CREATE OR REPLACE TRIGGER trg_alerta_vencimiento_lote
AFTER INSERT OR UPDATE OF fecha_vencimiento ON lote
FOR EACH ROW
BEGIN
    IF :NEW.fecha_vencimiento <= (SYSDATE + 30) THEN
        INSERT INTO alerta_stock (id_producto, mensaje)
        VALUES (:NEW.id_producto,
                '¡ALERTA! El lote ' || :NEW.numero_lote ||
                ' vence el ' || TO_CHAR(:NEW.fecha_vencimiento, 'DD/MM/YYYY') ||
                ' (' || :NEW.cantidad || ' unidades).');
    END IF;
END;
/