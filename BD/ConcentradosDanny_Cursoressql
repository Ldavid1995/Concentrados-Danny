-------------------* Cursores *----------------------------

CREATE OR REPLACE PROCEDURE sp_reporte_stock_critico AS

    CURSOR c_productos_bajos IS
        SELECT nombre, existencias, stock_minimo 
        FROM producto 
        WHERE existencias <= stock_minimo;
        
    v_nombre producto.nombre%TYPE;
    v_stock producto.existencias%TYPE;
    v_min producto.stock_minimo%TYPE;
BEGIN
    OPEN c_productos_bajos;
    LOOP
        FETCH c_productos_bajos INTO v_nombre, v_stock, v_min;
        EXIT WHEN c_productos_bajos%NOTFOUND;

        DBMS_OUTPUT.PUT_LINE('PRODUCTO CRÍTICO: ' || v_nombre || ' | Stock actual: ' || v_stock || ' (Mínimo: ' || v_min || ')');
    END LOOP;
    CLOSE c_productos_bajos;
END;
/

--2. SP_REPORTE_LOTES_POR_VENCER
-- Recorre los lotes activos que vencen dentro de los próximos 30 días
CREATE OR REPLACE PROCEDURE sp_reporte_lotes_por_vencer AS
    CURSOR c_lotes_vencer IS
        SELECT l.numero_lote, p.nombre, l.fecha_vencimiento, l.cantidad
        FROM lote l
        JOIN producto p ON p.id_producto = l.id_producto
        WHERE l.activo = 1
          AND l.fecha_vencimiento <= (SYSDATE + 30)
        ORDER BY l.fecha_vencimiento;

    v_numero_lote lote.numero_lote%TYPE;
    v_nombre      producto.nombre%TYPE;
    v_vencimiento lote.fecha_vencimiento%TYPE;
    v_cantidad    lote.cantidad%TYPE;
BEGIN
    OPEN c_lotes_vencer;
    LOOP
        FETCH c_lotes_vencer INTO v_numero_lote, v_nombre, v_vencimiento, v_cantidad;
        EXIT WHEN c_lotes_vencer%NOTFOUND;
        DBMS_OUTPUT.PUT_LINE('LOTE POR VENCER: ' || v_numero_lote ||
                              ' | Producto: ' || v_nombre ||
                              ' | Vence: ' || TO_CHAR(v_vencimiento, 'DD/MM/YYYY') ||
                              ' | Cantidad: ' || v_cantidad);
    END LOOP;
    CLOSE c_lotes_vencer;
END;
/

--3. SP_REPORTE_PEDIDOS_PENDIENTES
-- Recorre los pedidos en estado PENDIENTE, mostrando cliente y total
CREATE OR REPLACE PROCEDURE sp_reporte_pedidos_pendientes AS
    CURSOR c_pedidos_pendientes IS
        SELECT p.id_pedido, u.nombre || ' ' || u.apellidos AS cliente,
               p.fecha_pedido, p.total
        FROM pedido p
        JOIN usuario u ON u.id_usuario = p.id_usuario
        WHERE p.estado = 'PENDIENTE'
        ORDER BY p.fecha_pedido;

    v_id_pedido    pedido.id_pedido%TYPE;
    v_cliente      VARCHAR2(101);
    v_fecha_pedido pedido.fecha_pedido%TYPE;
    v_total        pedido.total%TYPE;
BEGIN
    OPEN c_pedidos_pendientes;
    LOOP
        FETCH c_pedidos_pendientes INTO v_id_pedido, v_cliente, v_fecha_pedido, v_total;
        EXIT WHEN c_pedidos_pendientes%NOTFOUND;
        DBMS_OUTPUT.PUT_LINE('PEDIDO #' || v_id_pedido ||
                              ' | Cliente: ' || v_cliente ||
                              ' | Fecha: ' || TO_CHAR(v_fecha_pedido, 'DD/MM/YYYY HH24:MI') ||
                              ' | Total: ' || v_total);
    END LOOP;
    CLOSE c_pedidos_pendientes;
END;
/

--4. SP_REPORTE_PRODUCTOS_SIN_MOVIMIENTO
-- Recorre productos activos que no aparecen en ningún detalle_pedido
CREATE OR REPLACE PROCEDURE sp_reporte_productos_sin_movimiento AS
    CURSOR c_sin_movimiento IS
        SELECT p.id_producto, p.nombre, p.stock
        FROM producto p
        WHERE p.activo = 1
          AND NOT EXISTS (
              SELECT 1 FROM detalle_pedido dp
              WHERE dp.id_producto = p.id_producto
          );

    v_id_producto producto.id_producto%TYPE;
    v_nombre      producto.nombre%TYPE;
    v_stock       producto.stock%TYPE;
BEGIN
    OPEN c_sin_movimiento;
    LOOP
        FETCH c_sin_movimiento INTO v_id_producto, v_nombre, v_stock;
        EXIT WHEN c_sin_movimiento%NOTFOUND;
        DBMS_OUTPUT.PUT_LINE('SIN MOVIMIENTO: [' || v_id_producto || '] ' ||
                              v_nombre || ' | Stock actual: ' || v_stock);
    END LOOP;
    CLOSE c_sin_movimiento;
END;
/

--5. SP_REPORTE_ROLES_USUARIOS
-- Cuenta cuántos usuarios tiene cada rol
CREATE OR REPLACE PROCEDURE sp_reporte_roles_usuarios AS
    CURSOR c_roles IS
        SELECT r.nombre_rol, COUNT(u.id_usuario) AS total_usuarios
        FROM rol r
        LEFT JOIN usuario u ON u.id_rol = r.id_rol
        GROUP BY r.nombre_rol;

    v_nombre_rol rol.nombre_rol%TYPE;
    v_total      NUMBER;
BEGIN
    OPEN c_roles;
    LOOP
        FETCH c_roles INTO v_nombre_rol, v_total;
        EXIT WHEN c_roles%NOTFOUND;
        DBMS_OUTPUT.PUT_LINE('ROL: ' || v_nombre_rol || ' | Usuarios asignados: ' || v_total);
    END LOOP;
    CLOSE c_roles;
END;
/

