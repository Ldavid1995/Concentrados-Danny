    LOOP
        FETCH c_direcciones INTO v_cliente, v_direccion, v_provincia, v_canton;
        EXIT WHEN c_direcciones%NOTFOUND;
        DBMS_OUTPUT.PUT_LINE('CLIENTE: ' || v_cliente ||
                              ' | Dirección: ' || v_direccion ||
                              ' | ' || v_canton || ', ' || v_provincia);
    END LOOP;
    CLOSE c_direcciones;
END;
/

--9. SP_REPORTE_CATEGORIAS_SIN_PRODUCTOS
-- Categorías activas que no tienen ningún producto asociado
