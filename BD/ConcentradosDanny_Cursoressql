--13. SP_REPORTE_CUPONES_VIGENTES
CREATE OR REPLACE PROCEDURE sp_reporte_cupones_vigentes AS
    CURSOR c_cupones IS
        SELECT codigo, descuento, fecha_vence
        FROM cupon
        WHERE activo = 1
          AND fecha_vence >= TRUNC(SYSDATE);

    v_codigo      cupon.codigo%TYPE;
    v_descuento   cupon.descuento%TYPE;
    v_fecha_vence cupon.fecha_vence%TYPE;
BEGIN
    OPEN c_cupones;
    LOOP
        FETCH c_cupones INTO v_codigo, v_descuento, v_fecha_vence;
        EXIT WHEN c_cupones%NOTFOUND;
        DBMS_OUTPUT.PUT_LINE('CUPÓN VIGENTE: ' || v_codigo ||
                              ' | Descuento: ' || v_descuento || '%' ||
                              ' | Vence: ' || TO_CHAR(v_fecha_vence, 'DD/MM/YYYY'));
    END LOOP;
    CLOSE c_cupones;
END;
/

