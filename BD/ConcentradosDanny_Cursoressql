--15. SP_REPORTE_PROMOCIONES_VIGENTES
CREATE OR REPLACE PROCEDURE sp_reporte_promociones_vigentes AS
    CURSOR c_promos IS
        SELECT nombre, porcentaje_descuento, fecha_fin
        FROM promocion
        WHERE activo = 1
          AND TRUNC(SYSDATE) BETWEEN fecha_inicio AND fecha_fin;

    v_nombre      promocion.nombre%TYPE;
    v_descuento   promocion.porcentaje_descuento%TYPE;
    v_fecha_fin   promocion.fecha_fin%TYPE;
BEGIN
    OPEN c_promos;
    LOOP
        FETCH c_promos INTO v_nombre, v_descuento, v_fecha_fin;
        EXIT WHEN c_promos%NOTFOUND;
        DBMS_OUTPUT.PUT_LINE('PROMOCIÓN VIGENTE: ' || v_nombre ||
                              ' | Descuento: ' || v_descuento || '%' ||
                              ' | Finaliza: ' || TO_CHAR(v_fecha_fin, 'DD/MM/YYYY'));
    END LOOP;
    CLOSE c_promos;
END;
/