    v_nombre_cat     categoria.nombre_categoria%TYPE;
BEGIN
    OPEN c_categorias;
    LOOP
        FETCH c_categorias INTO v_id_categoria, v_nombre_cat;
        EXIT WHEN c_categorias%NOTFOUND;
        DBMS_OUTPUT.PUT_LINE('CATEGORÍA SIN PRODUCTOS: [' || v_id_categoria || '] ' || v_nombre_cat);
    END LOOP;
    CLOSE c_categorias;
END;
/

--10. SP_REPORTE_ESPECIES_PRODUCTOS
-- Cantidad de productos asociados a cada especie
CREATE OR REPLACE PROCEDURE sp_reporte_especies_productos AS
    CURSOR c_especies IS
        SELECT e.nombre_especie, COUNT(pe.id_producto) AS total_productos
        FROM especie e
        LEFT JOIN producto_especie pe ON pe.id_especie = e.id_especie
        GROUP BY e.nombre_especie;

    v_nombre_especie especie.nombre_especie%TYPE;
    v_total          NUMBER;
BEGIN
    OPEN c_especies;
    LOOP
        FETCH c_especies INTO v_nombre_especie, v_total;
        EXIT WHEN c_especies%NOTFOUND;
        DBMS_OUTPUT.PUT_LINE('ESPECIE: ' || v_nombre_especie || ' | Productos asociados: ' || v_total);
    END LOOP;
    CLOSE c_especies;
END;
/

