--7. SP_REPORTE_TOKENS_EXPIRADOS
-- Tokens de recuperación vencidos que nunca se usaron
CREATE OR REPLACE PROCEDURE sp_reporte_tokens_expirados AS
    CURSOR c_tokens IS
        SELECT t.token, u.correo, t.fecha_expiracion
        FROM token_recuperacion t
        JOIN usuario u ON u.id_usuario = t.id_usuario
        WHERE t.usado = 0
          AND t.fecha_expiracion < CURRENT_TIMESTAMP;

    v_token      token_recuperacion.token%TYPE;
    v_correo     usuario.correo%TYPE;
    v_expiracion token_recuperacion.fecha_expiracion%TYPE;
BEGIN
    OPEN c_tokens;
    LOOP
        FETCH c_tokens INTO v_token, v_correo, v_expiracion;
        EXIT WHEN c_tokens%NOTFOUND;
        DBMS_OUTPUT.PUT_LINE('TOKEN EXPIRADO: ' || v_token ||
                              ' | Usuario: ' || v_correo ||
                              ' | Venció: ' || TO_CHAR(v_expiracion, 'DD/MM/YYYY HH24:MI'));
    END LOOP;
    CLOSE c_tokens;
END;
/

--8. SP_REPORTE_DIRECCIONES_USUARIO
-- Direcciones activas registradas por cliente
CREATE OR REPLACE PROCEDURE sp_reporte_direcciones_usuario AS
    CURSOR c_direcciones IS
        SELECT u.nombre || ' ' || u.apellidos AS cliente,
               d.direccion, d.provincia, d.canton
