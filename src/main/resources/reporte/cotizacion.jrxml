<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" 
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" 
              name="cotizacion" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    
    <parameter name="total" class="java.lang.Double"/>
    <parameter name="empresa" class="java.lang.String"/>
    
    <field name="producto.nombre" class="java.lang.String"/>
    <field name="producto.precio" class="java.lang.Double"/>
    <field name="cantidad" class="java.lang.Integer"/>

    <title>
        <band height="80">
            <textField>
                <reportElement x="0" y="0" width="555" height="40"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="22" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{empresa}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="0" y="40" width="555" height="30"/>
                <textElement textAlignment="Center">
                    <font size="14" isItalic="true"/>
                </textElement>
                <text><![CDATA[Proforma de Productos]]></text>
            </staticText>
        </band>
    </title>

    <columnHeader>
        <band height="30">
            <staticText>
                <reportElement x="0" y="0" width="280" height="30" backcolor="#E0E0E0"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[ Producto]]></text>
            </staticText>
            <staticText>
                <reportElement x="280" y="0" width="100" height="30"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Precio Unit.]]></text>
            </staticText>
            <staticText>
                <reportElement x="380" y="0" width="70" height="30"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Cant.]]></text>
            </staticText>
            <staticText>
                <reportElement x="450" y="0" width="105" height="30"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Subtotal ]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="25">
            <textField>
                <reportElement x="0" y="0" width="280" height="20"/>
                <textFieldExpression><![CDATA[$F{producto.nombre}]]></textFieldExpression>
            </textField>
            <textField pattern="₡#,##0">
                <reportElement x="280" y="0" width="100" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{producto.precio}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="380" y="0" width="70" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{cantidad}]]></textFieldExpression>
            </textField>
            <textField pattern="₡#,##0">
                <reportElement x="450" y="0" width="105" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[$F{producto.precio} * $F{cantidad}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="50">
            <line>
                <reportElement x="0" y="5" width="555" height="1"/>
            </line>
            <staticText>
                <reportElement x="350" y="10" width="100" height="30"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[TOTAL:]]></text>
            </staticText>
            <textField pattern="₡#,##0">
                <reportElement x="450" y="10" width="105" height="30" forecolor="#28A745"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="14" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{total}]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>
